# wrapi — copy to .env and fill in. NEVER commit your real .env.

# ─────────────────────────────────────────────────────────────────────────────
# Compiler (design time) — LLM connection. Read from the environment.
# ─────────────────────────────────────────────────────────────────────────────
LLM_BASE_URL=https://api.openai.com/v1     # any OpenAI-compatible base URL
LLM_API_KEY=sk-...                         # bearer token for that endpoint
LLM_MODEL=gpt-4o                           # optional (default: gpt-4o)

# Optional tuning for very large specs:
# LLM_MAX_OPS_PER_CALL=20                   # operations per LLM call (default 20)
# LLM_CONCURRENCY=4                         # concurrent LLM calls (default 4)
# FETCH_TIMEOUT_MS=15000                    # remote spec fetch timeout (default 15000)

# Optional: fallback spec URL used only when no CLI argument is given.
# Prefer passing the URL as an argument: `wrapi <url> [out]`.
# REMOTE_OPENAPI_URL=https://api.example.com/openapi.json

# ─────────────────────────────────────────────────────────────────────────────
# Gateway (run time)
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret   # HMAC signing key for HITL tokens
LEGACY_API_URL=https://api.example.com         # upstream base URL to proxy to

# GATEWAY_CONFIG_PATH=config/hitl_policy_map.json   # optional
# AGENT_SPEC_PATH=config/agent_openapi.json         # optional
# RESPONSE_SHAPES_PATH=config/response_shapes.json  # optional
# COMPOSITES_PATH=config/composites.json            # optional
# LISTEN_ADDR=:8080                                 # optional

# Egress transforms (on by default; set to off/false/0 to disable):
# ERROR_NORMALIZATION=on    # normalize upstream 4xx/5xx into a structured envelope
# RESPONSE_PROJECTION=on    # trim 2xx JSON bodies per config/response_shapes.json
